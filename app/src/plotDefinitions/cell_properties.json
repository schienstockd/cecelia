{
  "id": "cell_properties",
  "label": "Cell properties",
  "module": "behaviourAnalysis",
  "family": "summary",
  "chartTypes": ["boxplot", "violin", "strip", "bar", "histogram"],
  "whiteboardCompatible": true,
  "dataSource": {
    "popType": "live",
    "granularity": "cell",
    "measure": "live.cell.speed",
    "measureOptions": [
      "live.cell.speed",
      "live.cell.angle"
    ]
  },
  "scopeModes": ["per_image", "summarised"],
  "params": [
    { "key": "bins", "label": "Bins", "type": "int", "min": 10, "max": 100, "step": 5, "default": 30 }
  ]
}
