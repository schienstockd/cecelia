{
  "id": "spatial_cell_properties",
  "label": "Spatial cell properties",
  "module": "spatialAnalysis",
  "family": "summary",
  "chartTypes": ["boxplot", "violin", "strip", "bar", "histogram", "count"],
  "whiteboardCompatible": true,
  "dataSource": {
    "popType": "flow",
    "granularity": "cell"
  },
  "scopeModes": ["per_image", "summarised", "by_attr"],
  "params": [
    { "key": "bins", "label": "Bins", "type": "int", "min": 10, "max": 100, "step": 5, "default": 30 }
  ]
}
